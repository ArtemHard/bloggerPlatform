export async function createBlogPostHandler(
  req: Request<{ id: string }, {}, Omit<PostInputDto, 'blogId'>>,
  res: Response,
) {
  try {
    const blogId = req.params.id;

    const errors = postInputDtoValidation({ ...req.body, blogId });


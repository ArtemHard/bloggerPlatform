    const { pageNumber, pageSize } = parseQueryParams(queryInput);

    const postListOutput = mapToPostListPaginatedOutput(items, {
      pageNumber,
      pageSize,
      totalCount,
    });

    res.send(postListOutput);
  } catch (e: unknown) {
    errorsHandler(e, res);
  }
}

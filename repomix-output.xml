const blogsRepository = container.get<IBlogsRepository>(TYPES.BlogsRepository);
import { mapToBlogViewModel } from '../mappers/map-to-blog-view-model';

export const getBlogHandler = async (
  req: Request<{ id: string }>,
  res: Response,
) => {
